<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Big Red Button</title>
  <link rel="icon" type="image/x-icon" href="/css/icons/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/css/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/css/icons/favicon-16x16.png">
  <%- typeof renderStyles === 'function' ? renderStyles() : '' %>
  <%- typeof renderScripts === 'function' ? renderScripts() : '' %>
</head>
<body>
  <header class="site-header">
    <div class="branding">
      <a href="/">
        <img src="/css/icons/brb-logo.png" alt="Big Red Button Logo" class="logo-img" style="height:40px;vertical-align:middle;" />
      </a>
    </div>
    <nav class="nav">
      <div class="nav-center">
        <a href="/">Home</a>
        <a href="/products">Products</a>
        <a href="/register">Register</a>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <a href="/users">Users</a>
        <% } %>
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
          <a href="/logout">Logout</a>
        <% } else { %>
          <a href="/login">Login</a>
        <% } %>
      </div>
      <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
        <a href="/profile" class="profile-btn" title="Profile">
          <img src="/css/icons/profile.png" alt="Profile" class="profile-icon" />
        </a>
      <% } %>
    </nav>
  </header>

  <% const flashMessages = typeof flash === 'function' ? flash() : { success: [], error: [], warning: [], info: [] }; %>
  <% if (flashMessages.success.length || flashMessages.error.length || flashMessages.warning.length || flashMessages.info.length) { %>
    <div class="flash-messages">
      <% flashMessages.success.forEach(msg => { %>
        <div class="flash flash-success"><%= msg %></div>
      <% }); %>
      <% flashMessages.error.forEach(msg => { %>
        <div class="flash flash-error"><%= msg %></div>
      <% }); %>
      <% flashMessages.warning.forEach(msg => { %>
        <div class="flash flash-warning"><%= msg %></div>
      <% }); %>
      <% flashMessages.info.forEach(msg => { %>
        <div class="flash flash-info"><%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <main class="page">
