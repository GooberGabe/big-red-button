<%- include('partials/header', { title }) %>
<h2>Register</h2>
<form action="/register" method="POST" class="form">
  <% if (errors && errors.length) { %>
    <ul class="errors">
      <% errors.forEach(function(error) { %>
        <li><%= error %></li>
      <% }) %>
    </ul>
  <% } %>
  <label>Email:<input type="email" name="email" value="<%= formData.email || '' %>" required></label><br>
  <label>Username:<input type="text" name="username" value="<%= formData.username || '' %>" required></label><br>
  <label>Password:<input type="password" name="password" required></label><br>
  <label>Confirm Password:<input type="password" name="confirmPassword" required></label><br>
  <button type="submit">Register</button>
</form>
<%- include('partials/footer') %>
