<%- include('partials/header') %>
<section class="section">
  <h1>Products</h1>
  <div class="grid">
    <% products.forEach((item) => { %>
      <article class="card">
        <h2><%= item.name %></h2>
        <p><%= item.description %></p>
        <p class="price">$<%= item.price.toFixed(2) %></p>
        <button class="button" type="button">Add to cart</button>
      </article>
    <% }) %>
  </div>
</section>
<%- include('partials/footer') %>
