<%- include('partials/header', { title }) %>
<h2>All Users</h2>
<table class="user-table">
  <thead>
    <tr><th>ID</th><th>Email</th><th>Username</th></tr>
  </thead>
  <tbody>
    <% users.forEach(function(user) { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.email %></td>
        <td><%= user.username %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('partials/footer') %>
